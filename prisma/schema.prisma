generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum CampaignStatus {
  draft
  active
  archived
}

enum SponsorshipStatus {
  draft
  in_conversation
  reserved
  pending_payment
  confirmed
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id        String     @id // Clerk user ID
  email     String     @unique
  name      String?
  createdAt DateTime   @default(now())
  campaigns Campaign[]
}

model Campaign {
  id     String         @id @default(cuid())
  userId String
  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  name   String
  slug   String         @unique
  status CampaignStatus @default(draft)

  isPublic Boolean @default(false)

  // ── Event details ─────────────────────────────────
  eventDate DateTime?
  venue     String?

  // ── Ticket link ───────────────────────────────────
  ticketUrl        String?
  ticketButtonText String?

  // ── Legacy content fields (kept for DB compatibility) ─
  organizationOverview String?
  audienceSummary      String?
  campaignGoals        String?

  // ── CTA ───────────────────────────────────────────
  ctaText   String?
  ctaEmails String[] // Multiple contact emails

  // ── Legacy section customization (kept for DB compatibility) ─
  aboutTitle    String?
  audienceTitle String?
  goalsTitle    String?
  showAbout     Boolean @default(true)
  showAudience  Boolean @default(true)
  showGoals     Boolean @default(true)

  // ── Visual ────────────────────────────────────────
  heroImageUrl   String?
  primaryColor   String?
  secondaryColor String?
  templateId     String  @default("default")

  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  tiers     SponsorshipTier[]
  sections  CampaignSection[]

  @@index([userId])
  @@index([slug])
}

// Dynamic content sections — replaces the 3 hardcoded content fields
model CampaignSection {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  title     String
  content   String
  sortOrder Int      @default(0)

  createdAt DateTime @default(now())

  @@index([campaignId])
}

model SponsorshipTier {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  name        String
  price       Decimal  @db.Decimal(10, 2)
  totalSlots  Int
  description String?
  benefits    String[]
  sortOrder   Int      @default(0)

  createdAt    DateTime      @default(now())
  sponsorships Sponsorship[]

  @@index([campaignId])
}

model Sponsorship {
  id     String          @id @default(cuid())
  tierId String
  tier   SponsorshipTier @relation(fields: [tierId], references: [id], onDelete: Cascade)

  sponsorName    String
  sponsorEmail   String?
  sponsorCompany String?
  sponsorLogoUrl String?
  status         SponsorshipStatus @default(draft)

  isPublic Boolean @default(true)
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tierId])
}
